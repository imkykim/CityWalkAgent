# ─────────────────────────────────────────────────────────────────────
# CityWalkAgent — Environment Configuration
# Copy this file to `.env` and fill in your API keys.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# Google Maps Platform (REQUIRED)
# Enable: Maps JavaScript API, Street View Static API, Map Tiles API, Directions API
# Get key: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# VLM endpoint — OpenAI-compatible chat completions API (REQUIRED)
# Tested with Qwen3-VL-30B-A3B. Any OpenAI-compatible vision endpoint works.
# Examples:
#   DashScope (Alibaba):  https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   OpenAI:               https://api.openai.com/v1
#   Together AI:          https://api.together.xyz/v1
QWEN_VLM_API_URL=https://your-vlm-endpoint/v1
QWEN_VLM_API_KEY=your_vlm_api_key_here
QWEN_VLM_MODEL=Qwen3-VL-30B-A3B-Instruct-FP8

# Default evaluation framework (OPTIONAL)
# Controls which perceptual dimensions are used. Built-in options: place_pulse_2.0
# DEFAULT_FRAMEWORK_ID=place_pulse_2.0

# Mapillary (OPTIONAL — reserved for future SVI source support)
# MAPILLARY_API_KEY=your_mapillary_api_key_here
